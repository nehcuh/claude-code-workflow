# <%= platform_name %> Platform Configuration
# Generated by claude-code-workflow configuration generator
# Template Version: 1.1.0

<%#
  This template generates platform configuration for config/platforms.yaml

  Required variables:
    - platform_id: Unique identifier (e.g., "claude-code", "opencode")
    - platform_name: Display name (e.g., "Claude Code", "OpenCode")
    - description: Platform description

  Optional variables:
    - doc_types: Array of document types (default: basic set)
    - runtime_dirs: Array of runtime directories for global mode (default: [])
    - copy_mode_global: "full", "minimal", or "none" (default: "minimal")
    - copy_mode_project: "full", "minimal", or "none" (default: "minimal")
    - has_native_config: Boolean (default: false)
    - native_config_filename: Native config filename (default: nil)
    - native_config_builder: Builder method for global native config
    - native_config_project_builder: Builder method for project native config
    - special_handling: Hash of special flags (default: {})
%>

<%# Set defaults %>
<% doc_types ||= %w[behavior safety task_routing test_standards] %>
<% runtime_dirs ||= [] %>
<% copy_mode_global ||= "minimal" %>
<% copy_mode_project ||= "minimal" %>
<% has_native_config ||= false %>
<% native_config_builder ||= "#{platform_id.tr('-', '_')}_config" %>
<% native_config_project_builder ||= "#{platform_id.tr('-', '_')}_project_config" %>
<% special_handling ||= {} %>

<%= platform_id %>:
  target_id: <%= platform_id %>
  display_name: <%= platform_name %>
  description: <%= description %>

  output_paths:
    global:
      vibe_subdir: .vibe/<%= platform_id %>
      entrypoint_name: <%= entrypoint_name || "AGENTS.md" %>
    project:
      vibe_subdir: .vibe/<%= platform_id %>
      entrypoint_name: <%= entrypoint_name || "AGENTS.md" %>

  doc_types:
    global: [<%= doc_types.join(', ') %>]
    project: [<%= doc_types.join(', ') %>]
<% if has_native_config %>

  native_config:
    global:
      type: json
      filename: <%= native_config_filename %>
      builder: <%= native_config_builder %>
    project:
      type: json
      filename: <%= native_config_filename %>
      builder: <%= native_config_project_builder %>
<% else %>

  native_config: {}
<% end %>

  runtime_dirs:
    global: [<%= runtime_dirs.map { |d| "'#{d}'" }.join(', ') %>]
    project: []

  copy_mode:
    global: <%= copy_mode_global %>
    project: <%= copy_mode_project %>
<% unless special_handling.empty? %>

  special_handling:
<% special_handling.each do |key, value| %>
    <%= key %>: <%= value %>
<% end %>
<% end %>
